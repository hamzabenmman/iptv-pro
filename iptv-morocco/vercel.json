{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "env": {
    "npm_config_legacy_peer_deps": "true",
    "npm_config_ignore_scripts": "true"
  },
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/ar",
      "destination": "/",
      "has": [
        {
          "type": "header",
          "key": "accept-language",
          "value": ".*ar.*"
        }
      ],
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/blog/generate",
      "schedule": "0 */1 * * *"
    }
  ]
}
